PORT=3001
FRONTEND_URL=http://localhost:5173
# Comma-separated list of origins allowed to call the API (CORS).
# In prod, include every domain the frontend is served from, e.g.
# https://ediaspora-ks.com,https://www.ediaspora-ks.com,https://e-diaspora.vercel.app
ALLOWED_ORIGINS=http://localhost:5173
DATABASE_URL=
RESEND_API_KEY=
EMAIL_FROM=eDiaspora <noreply@yourdomain.com>

# Frontend only: leave empty for local dev (uses the Vite proxy below).
# In prod (Vercel), set this to your Render backend URL, e.g.
# https://ediaspora-api.onrender.com
VITE_API_URL=
